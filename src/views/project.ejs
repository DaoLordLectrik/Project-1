<%- include('partials/header') %>
<main>
  <h1><%= pageTitle %></h1>

  <h2><%= projectDetails.title %></h2>
  <p><%= new Date(projectDetails.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
  <p>Location: <%= projectDetails.location %></p>
  <p><%= projectDetails.description %></p>
  <p>Organized by: <a href="/organizations/<%= projectDetails.organization_id %>"><%= projectDetails.organization_name %></a></p>

  <h3>Categories</h3>
  <ul class="tag-list">
    <% categories.forEach(category => { %>
      <li><a href="/category/<%= category.category_id %>"><%= category.category_name %></a></li>
    <% }); %>
  </ul>
</main>
<%- include('partials/footer') %>