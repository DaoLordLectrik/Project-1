<%- include('partials/header') %>

<section class="hero">
  <h1><%= pageTitle %></h1>

    <% projects.forEach(project => { %>
      <div class="card">
        <p>
          <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>:
          <strong><a href="/project/<%= project.project_id %>"><%= project.title %></a></strong>
          (<a href="/organizations/<%= project.organization_id %>"><%= project.organization_name %></a>)
        </p>
      </div>
    <% }); %>

</section>

<%- include('partials/footer') %>