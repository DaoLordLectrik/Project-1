<%- include('partials/header') %>

<section class="hero">
  <h1><%= pageTitle %></h1>

    <% projects.forEach(project => { %>
      <div class="card">
        <p>
          <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>:
          <strong><%= project.title %></strong> (<%= project.organization_name %>)
        </p>
      </div>
    <% }); %>

